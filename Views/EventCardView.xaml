<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Campus.Converters"
             x:Class="Campus.Views.EventCardView">
    <ContentView.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    </ContentView.Resources>
    <VerticalStackLayout Padding="10" Spacing="5">

        <!-- Title -->
        <Label Text="{Binding Title}"
               FontSize="18"
               FontAttributes="Bold" />

        <!-- Description -->
        <Label Text="{Binding Description}"
               FontSize="14" />
        <Label 
    Text="{Binding Status}"
    TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
    FontAttributes="Bold" />

        <!-- Image (optional nếu có) -->
        <Image Source="{Binding ImageUrl}"
               HeightRequest="150"
               Aspect="AspectFill" />
        
        <Button 
    Text="Unregister"
    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UnregisterCommand}"
    CommandParameter="{Binding .}" />
        

    </VerticalStackLayout>

</ContentView>