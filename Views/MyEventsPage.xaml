<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Campus.Views"
             xmlns:converters="clr-namespace:Campus.Converters"
             x:Class="Campus.Views.MyEventsPage">
    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </ContentPage.Resources>

    <Grid>

        <!-- 🔥 LIST -->
        <CollectionView 
            ItemsSource="{Binding MyEventsList}"
            IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <views:EventCardView />
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- 🔥 EMPTY STATE -->
        <VerticalStackLayout
            IsVisible="{Binding IsEmpty}"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Label Text="😢"
                   FontSize="40"
                   HorizontalOptions="Center"/>

            <Label Text="No registered events"
                   FontSize="16"
                   HorizontalOptions="Center"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>